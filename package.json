{
  "name": "cuentas",
  "version": "1.0.0",
  "description": "personal finance app made with React Native and Node.js",
  "main": "index.js",
  "scripts": {
    "app:dev": "cd ./cuentas && npx expo start",
    "app:build:production": "cd ./cuentas && npm run build:production",
    "server:dev": "cd ./backend && npm run dev",
    "parser:setup": "cd ./pdf-parser && python3 -m venv .venv && ./.venv/bin/pip install -r requirements.txt",
    "parser:dev": "cd ./pdf-parser && ./.venv/bin/uvicorn app.main:app --reload --port 8001",
    "dev": "concurrently -n app,server,parser -c cyan,magenta,yellow \"npm:app:dev\" \"npm:server:dev\" \"npm:parser:dev\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateo-gomez/cuentas.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mateo-gomez/cuentas/issues"
  },
  "homepage": "https://github.com/mateo-gomez/cuentas#readme",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
