{
  "name": "cuentas",
  "version": "1.0.0",
  "description": "personal finance app made with React Native and Node.js",
  "main": "index.js",
  "scripts": {
    "app:dev": "cd ./cuentas && npx expo start",
    "server:dev": "cd ./backend && npm run dev",
    "parser:dev": "cd ./pdf-parser && uvicorn app.main:app --reload --port 8000",
    "dev": "concurrently -n app,server -c cyan,magenta \"npm:app:dev\" \"npm:server:dev\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "eas build --android --profile production --platform all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateo-gomez/cuentas.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mateo-gomez/cuentas/issues"
  },
  "homepage": "https://github.com/mateo-gomez/cuentas#readme",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
