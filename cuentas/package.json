{
  "name": "cuentas",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "ts": "tsc",
    "test": "jest",
    "build:beta": "eas build --android --profile beta --platform all",
    "build:production": "eas build --android --profile production --platform all",
    "submit:beta": "eas submit --android --profile beta",
    "submit:production": "eas submit --android --profile production"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@types/react": "~19.1.10",
    "accordion-collapse-react-native": "^1.1.1",
    "expo": "^54.0.34",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-drawer-layout": "^3.2.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.12.1",
    "react-native-virtual-keyboard": "^1.2.2",
    "react-native-worklets": "0.5.1",
    "react-router-native": "^6.14.1",
    "typescript": "~5.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.14",
    "dotenv": "^16.3.1",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^16.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "overrides": {
    "react-native-appwrite": {
      "expo-file-system": "18.*.*",
      "react-native": ">=0.76.7 <1.0.0"
    }
  }
}
